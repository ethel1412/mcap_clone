{
  "extends": [
    "development"
  ],
  "hints": {
    "meta-viewport": "off",
    "axe/language": [
      "default",
      {
        "html-has-lang": "off"
      }
    ],
    "no-inline-styles": "off",
    "axe/forms": [
      "default",
      {
        "label": "off",
        "select-name": "off"
      }
    ],
    "axe/name-role-value": [
      "default",
      {
        "button-name": "off",
        "link-name": "off"
      }
    ],
    "button-type": "off",
    "axe/text-alternatives": [
      "default",
      {
        "document-title": "off"
      }
    ],
    "axe/aria": [
      "default",
      {
        "aria-command-name": "off",
        "aria-required-parent": "off",
        "aria-progressbar-name": "off"
      }
    ],
    "detect-css-reflows/composite": "off",
    "meta-charset-utf-8": "off",
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "user-select",
          "min-height: auto",
          "backdrop-filter"
        ]
      }
    ],
    "css-prefix-order": "off"
  }
}